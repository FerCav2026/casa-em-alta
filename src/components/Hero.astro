---
---

<section class="relative bg-gradient-to-br from-slate-900 via-slate-800 to-orange-950 overflow-hidden">
  <!-- Elementos decorativos de fundo -->
  <div class="absolute inset-0 opacity-10">
    <div class="absolute top-20 left-10 w-72 h-72 bg-orange-500 rounded-full blur-3xl"></div>
    <div class="absolute bottom-10 right-10 w-96 h-96 bg-orange-400 rounded-full blur-3xl"></div>
  </div>

  <div class="relative max-w-6xl mx-auto px-4 py-24 md:py-32 flex flex-col items-center text-center gap-6">
    <!-- Tag de credibilidade -->
    <span class="inline-flex items-center gap-2 bg-orange-500/20 border border-orange-500/30 text-orange-300 text-xs font-semibold px-4 py-1.5 rounded-full uppercase tracking-widest">
      Reviews honestos sem enrolação
    </span>

    <!-- Headline principal -->
    <h1 class="text-4xl md:text-6xl font-black text-white leading-tight max-w-4xl">
      As melhores
      <span class="text-orange-400"> utilidades para sua casa</span>,
      testadas e aprovadas
    </h1>

    <!-- Subtítulo -->
    <p class="text-lg md:text-xl text-slate-300 max-w-2xl leading-relaxed">
      Comparativos detalhados, reviews honestos e as melhores ofertas do mercado para você comprar com segurança e economizar de verdade.
    </p>

    <!-- CTAs -->
    <div class="flex flex-col sm:flex-row gap-4 mt-4">
      <a
        href="#posts"
        class="bg-orange-500 hover:bg-orange-400 text-white font-bold px-8 py-4 rounded-full text-base transition-all shadow-lg shadow-orange-500/30 hover:shadow-orange-500/50 hover:-translate-y-0.5"
      >
        Ver Melhores Reviews
      </a>
    </div>
  </div>
</section>
