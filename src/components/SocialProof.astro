---
---

<section class="bg-slate-50 border-y border-slate-100 py-12">
  <div class="max-w-6xl mx-auto px-4">
    <p class="text-center text-sm font-semibold text-slate-400 uppercase tracking-widest mb-8">
      Produtos comparados nas principais lojas
    </p>
    <div class="flex flex-wrap justify-center items-center gap-6">

      <!-- Amazon -->
      <div class="flex items-center justify-center px-8 py-4 rounded-2xl bg-white border border-slate-200 shadow-sm hover:shadow-md transition-shadow min-w-[160px]">
        <svg viewBox="0 0 120 40" xmlns="http://www.w3.org/2000/svg" class="h-9 w-auto" aria-label="Amazon">
          <!-- Wordmark "amazon" -->
          <text x="4" y="26" font-family="Arial, sans-serif" font-size="24" font-weight="900" fill="#232F3E" letter-spacing="-0.5">amazon</text>
          <!-- Sorriso laranja (smile arrow) -->
          <path d="M22 33 Q60 44 98 33" stroke="#FF9900" stroke-width="3.5" fill="none" stroke-linecap="round"/>
          <polygon points="95,29 102,33 95,37" fill="#FF9900"/>
        </svg>
      </div>

      <!-- Mercado Livre -->
      <div class="flex items-center justify-center px-8 rounded-2xl bg-white border border-slate-200 shadow-sm hover:shadow-md transition-shadow min-w-[160px]" style="height:68px; overflow:hidden;">
        <img src="/images/logo-mercado-livre.jpg" alt="Mercado Livre" style="height:110px; width:auto; max-width:200px; object-fit:contain;" />
      </div>

      <!-- Shopee -->
      <div class="flex items-center justify-center px-8 py-4 rounded-2xl bg-white border border-slate-200 shadow-sm hover:shadow-md transition-shadow min-w-[160px]">
        <svg viewBox="0 0 120 44" xmlns="http://www.w3.org/2000/svg" class="h-9 w-auto" aria-label="Shopee">
          <!-- Sacola laranja -->
          <rect x="2" y="16" width="28" height="24" rx="4" fill="#EE4D2D"/>
          <!-- Alca da sacola -->
          <path d="M8 16 Q8 6 16 6 Q24 6 24 16" stroke="#EE4D2D" stroke-width="3.5" fill="none" stroke-linecap="round"/>
          <!-- Brilho na sacola -->
          <rect x="2" y="16" width="28" height="8" rx="4" fill="#FF6640" opacity="0.5"/>
          <!-- Texto shopee -->
          <text x="36" y="28" font-family="Arial, sans-serif" font-size="18" font-weight="900" fill="#EE4D2D">shopee</text>
        </svg>
      </div>

    </div>
  </div>
</section>
