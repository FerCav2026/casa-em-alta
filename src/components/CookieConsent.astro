---
// Banner de consentimento de cookies (LGPD)
// A analytics (Microsoft Clarity) so carrega se a pessoa aceitar.
// Escolha salva em localStorage: 'cea-consent' = 'accepted' | 'rejected'
const CLARITY_ID = 'wyo4kb1u7h';
---

<div
  id="cookie-consent"
  class="fixed inset-x-0 bottom-0 z-[60] hidden px-4 pb-4 sm:inset-x-auto sm:right-4 sm:left-auto sm:bottom-4 sm:px-0"
  role="dialog"
  aria-modal="false"
  aria-labelledby="cc-title"
>
  <div class="mx-auto w-full max-w-lg rounded-2xl border border-slate-200 bg-white p-6 shadow-2xl sm:mx-0">
    <!-- VISAO PRINCIPAL -->
    <div id="cc-main">
      <div class="mb-3 flex items-center justify-center relative">
        <h2 id="cc-title" class="text-lg font-bold text-slate-800">Gerenciar consentimento</h2>
        <button
          type="button"
          data-cc-action="close"
          aria-label="Fechar"
          class="absolute right-0 top-0 text-slate-400 hover:text-slate-700 transition-colors"
        >
          <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
        </button>
      </div>
      <p class="mb-5 text-sm leading-relaxed text-slate-600">
        Para proporcionar uma melhor experiência, usamos tecnologias como cookies para armazenar e/ou acessar informações do dispositivo. O consentimento com essas tecnologias nos permite processar dados como comportamento da navegação ou IDs exclusivos neste site. O não consentimento ou a revogação do consentimento pode afetar negativamente determinados recursos e funções.
      </p>
      <div class="grid grid-cols-1 gap-3 sm:grid-cols-3">
        <button
          type="button"
          data-cc-action="accept"
          class="rounded-lg bg-orange-500 px-5 py-3 text-sm font-bold text-white transition-colors hover:bg-orange-600"
        >
          Aceitar
        </button>
        <button
          type="button"
          data-cc-action="reject"
          class="rounded-lg bg-slate-100 px-5 py-3 text-sm font-semibold text-slate-700 transition-colors hover:bg-slate-200"
        >
          Rejeitar
        </button>
        <button
          type="button"
          data-cc-action="prefs"
          class="rounded-lg border border-slate-300 bg-white px-5 py-3 text-sm font-semibold text-slate-700 transition-colors hover:bg-slate-50"
        >
          Ver preferências
        </button>
      </div>
    </div>

    <!-- VISAO PREFERENCIAS -->
    <div id="cc-prefs" class="hidden">
      <div class="mb-3 flex items-center justify-center relative">
        <h2 class="text-lg font-bold text-slate-800">Preferências de consentimento</h2>
        <button
          type="button"
          data-cc-action="close"
          aria-label="Fechar"
          class="absolute right-0 top-0 text-slate-400 hover:text-slate-700 transition-colors"
        >
          <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
        </button>
      </div>

      <div class="mb-5 space-y-4">
        <div class="flex items-start justify-between gap-4 rounded-xl bg-slate-50 p-4">
          <div>
            <p class="text-sm font-semibold text-slate-800">Necessários</p>
            <p class="mt-1 text-xs text-slate-500">Essenciais para o funcionamento do site. Não podem ser desativados.</p>
          </div>
          <span class="mt-1 shrink-0 rounded-full bg-slate-200 px-3 py-1 text-xs font-semibold text-slate-500">Sempre ativo</span>
        </div>

        <div class="flex items-start justify-between gap-4 rounded-xl bg-slate-50 p-4">
          <div>
            <p class="text-sm font-semibold text-slate-800">Estatísticas</p>
            <p class="mt-1 text-xs text-slate-500">Ajudam a entender como os visitantes usam o site (Microsoft Clarity), de forma anônima.</p>
          </div>
          <label class="relative mt-1 inline-flex shrink-0 cursor-pointer items-center">
            <input type="checkbox" id="cc-toggle-analytics" class="peer sr-only" checked />
            <div class="h-6 w-11 rounded-full bg-slate-300 after:absolute after:left-[2px] after:top-[2px] after:h-5 after:w-5 after:rounded-full after:bg-white after:transition-all after:content-[''] peer-checked:bg-orange-500 peer-checked:after:translate-x-full"></div>
          </label>
        </div>
      </div>

      <div class="grid grid-cols-1 gap-3 sm:grid-cols-2">
        <button
          type="button"
          data-cc-action="save"
          class="rounded-lg bg-orange-500 px-5 py-3 text-sm font-bold text-white transition-colors hover:bg-orange-600"
        >
          Salvar preferências
        </button>
        <button
          type="button"
          data-cc-action="accept"
          class="rounded-lg border border-slate-300 bg-white px-5 py-3 text-sm font-semibold text-slate-700 transition-colors hover:bg-slate-50"
        >
          Aceitar tudo
        </button>
      </div>
    </div>
  </div>
</div>

<script is:inline define:vars={{ CLARITY_ID }}>
  (function () {
    var KEY = 'cea-consent';
    var banner = document.getElementById('cookie-consent');
    if (!banner) return;
    var mainView = document.getElementById('cc-main');
    var prefsView = document.getElementById('cc-prefs');
    var toggle = document.getElementById('cc-toggle-analytics');
    var clarityLoaded = false;

    function loadClarity() {
      if (clarityLoaded || !CLARITY_ID) return;
      clarityLoaded = true;
      (function (c, l, a, r, i, t, y) {
        c[a] = c[a] || function () { (c[a].q = c[a].q || []).push(arguments); };
        t = l.createElement(r); t.async = 1; t.src = 'https://www.clarity.ms/tag/' + i;
        y = l.getElementsByTagName(r)[0]; y.parentNode.insertBefore(t, y);
      })(window, document, 'clarity', 'script', CLARITY_ID);
    }

    function show() {
      banner.classList.remove('hidden');
      mainView.classList.remove('hidden');
      prefsView.classList.add('hidden');
    }
    function hide() { banner.classList.add('hidden'); }
    function showPrefs() {
      mainView.classList.add('hidden');
      prefsView.classList.remove('hidden');
    }

    function save(value) {
      try { localStorage.setItem(KEY, value); } catch (e) {}
      if (value === 'accepted') loadClarity();
      hide();
    }

    var saved = null;
    try { saved = localStorage.getItem(KEY); } catch (e) {}

    if (saved === 'accepted') {
      loadClarity();
    } else if (saved === 'rejected') {
      // nada: analytics permanece desativada
    } else {
      show();
    }

    banner.addEventListener('click', function (ev) {
      var el = ev.target.closest('[data-cc-action]');
      if (!el) return;
      var action = el.getAttribute('data-cc-action');
      if (action === 'accept') save('accepted');
      else if (action === 'reject') save('rejected');
      else if (action === 'close') hide();
      else if (action === 'prefs') showPrefs();
      else if (action === 'save') save(toggle && toggle.checked ? 'accepted' : 'rejected');
    });

    // Permite reabrir o banner a partir de um link no rodape (data-cc-open)
    document.querySelectorAll('[data-cc-open]').forEach(function (link) {
      link.addEventListener('click', function (e) { e.preventDefault(); show(); });
    });
  })();
</script>
