---
import { posts } from '../data/posts';
---

<section id="posts" class="py-20 bg-white">
  <div class="max-w-6xl mx-auto px-4">
    <!-- Título da seção -->
    <div class="text-center mb-12">
      <span class="text-orange-500 font-semibold text-sm uppercase tracking-widest">Conteúdo em destaque</span>
      <h2 class="text-3xl md:text-4xl font-black text-slate-900 mt-2">Os Melhores Posts</h2>
      <p class="text-slate-500 mt-3 max-w-xl mx-auto">Reviews, comparativos e guias de compra para você tomar a melhor decisão.</p>
    </div>

    <!-- Grid 3x3 -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {posts.slice().reverse().map((post) => (
        <article class="group bg-white rounded-2xl border border-slate-100 shadow-sm hover:shadow-md transition-all hover:-translate-y-1 overflow-hidden flex flex-col">
          <!-- Imagem de capa -->
          <div class="w-full h-48 overflow-hidden bg-gradient-to-br from-slate-100 to-slate-200 flex items-center justify-center">
            {post.imagem ? (
              <img
                src={post.imagem}
                alt={`Capa: ${post.titulo}`}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                loading="lazy"
              />
            ) : (
              <div class="text-center">
                <div class="w-12 h-12 rounded-xl bg-orange-100 flex items-center justify-center mx-auto mb-2">
                  <svg class="w-6 h-6 text-orange-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                  </svg>
                </div>
                <span class="text-xs text-slate-400">Em breve</span>
              </div>
            )}
          </div>

          <div class="p-5 flex flex-col flex-1 gap-3">
            <!-- Categoria e tempo -->
            <div class="flex items-center justify-between">
              <a
                href={`/categorias/${post.categoria}`}
                class={`text-xs font-semibold px-2.5 py-1 rounded-full ${post.categoriaColor} hover:opacity-80 transition-opacity`}
              >
                {post.categoriaLabel}
              </a>
              <span class="text-xs text-slate-400">{post.tempo}</span>
            </div>

            <!-- Título -->
            <h3 class="font-bold text-slate-900 text-base leading-snug group-hover:text-orange-500 transition-colors">
              <a href={`/posts/${post.slug}`}>{post.titulo}</a>
            </h3>

            <!-- Resumo -->
            <p class="text-sm text-slate-500 leading-relaxed flex-1">{post.resumo}</p>

            <!-- Link -->
            <a
              href={`/posts/${post.slug}`}
              class="text-sm font-semibold text-orange-500 hover:text-orange-600 flex items-center gap-1 mt-auto transition-colors"
            >
              Ler artigo completo
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </a>
          </div>
        </article>
      ))}
    </div>

    <!-- Botão ver todos -->
    <div class="text-center mt-12">
      <a href="/posts" class="inline-flex items-center gap-2 border-2 border-orange-500 text-orange-500 hover:bg-orange-500 hover:text-white font-bold px-8 py-3 rounded-full transition-all">
        Ver todos os artigos
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
      </a>
    </div>
  </div>
</section>
