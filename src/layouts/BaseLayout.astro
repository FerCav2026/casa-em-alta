---
interface Props {
  title?: string;
  description?: string;
  image?: string;
  canonicalURL?: string;
  type?: 'website' | 'article';
  schema?: object;
}

const {
  title = 'Casa em Alta - Reviews, Comparativos e Ofertas de Utilidades Domésticas',
  description = 'Encontre as melhores utilidades domésticas com reviews honestos, comparativos detalhados e as melhores ofertas do mercado.',
  image = '/images/og-default.png',
  type = 'website',
  schema,
} = Astro.props;

const rawPath = Astro.url.pathname.replace(/\/$/, '') || '/';
const canonicalURL = Astro.props.canonicalURL ?? new URL(rawPath, Astro.site).href;
const imageURL = new URL(image, Astro.site).href;

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Casa em Alta',
  url: Astro.site?.href,
  description,
};
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="google-site-verification" content="NsAZhDKWww5qGnuGSlfm-9CGIeWHGmaDGp_0Dn_P7bM" />
    <meta name="p:domain_verify" content="6815b172bcb7a489fdf002321ffc37dc" />

    <!-- SEO básico -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Open Graph -->
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={imageURL} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content="Casa em Alta" />
    <meta property="og:locale" content="pt_BR" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageURL} />

    <!-- Fonte otimizada: preload + font-display swap -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap"
      rel="stylesheet"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
    </noscript>

    <!-- Schema Markup: WebSite (toda página) -->
    <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />

    <!-- Schema Markup: específico da página (ex: BlogPosting) -->
    {schema && <script type="application/ld+json" set:html={JSON.stringify(schema)} />}

    <!-- Microsoft Clarity -->
    <script type="text/javascript">
      (function(c,l,a,r,i,t,y){
        c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
        t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
        y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
      })(window, document, "clarity", "script", "wyo4kb1u7h");
    </script>
  </head>
  <body class="bg-white font-sans text-slate-900 antialiased">
    <header class="sticky top-0 z-50 bg-white border-b border-slate-100 shadow-sm">
      <div class="max-w-6xl mx-auto px-4 h-16 flex items-center justify-between">
        <a href="/" class="flex items-center gap-2.5" aria-label="Casa em Alta - Página inicial">
          <svg viewBox="0 0 36 36" class="w-9 h-9" xmlns="http://www.w3.org/2000/svg">
            <rect width="36" height="36" rx="8" fill="#f97316"/>
            <polygon points="18,6 30,17 6,17" fill="white"/>
            <rect x="8" y="16" width="20" height="14" fill="white"/>
            <rect x="14" y="22" width="8" height="8" rx="1.5" fill="#f97316"/>
            <rect x="21" y="19" width="5" height="5" rx="1" fill="#fed7aa"/>
          </svg>
          <span class="text-xl font-black text-slate-800"><span class="text-orange-500">Casa</span> em Alta</span>
        </a>
        <nav aria-label="Menu principal" class="hidden md:flex items-center gap-8 text-sm font-medium text-slate-600">
          <a href="/#posts" class="hover:text-orange-500 transition-colors">Melhores Posts</a>
          <a href="/categorias/rankings-e-listas" class="hover:text-orange-500 transition-colors">Rankings</a>
          <a href="/categorias/guia-de-compra" class="hover:text-orange-500 transition-colors">Guias</a>
          <a href="/sobre" class="hover:text-orange-500 transition-colors">Sobre</a>
        </nav>
        <a href="/posts" class="bg-orange-500 hover:bg-orange-600 text-white text-sm font-semibold px-4 py-2 rounded-full transition-colors">
          Ver Ofertas
        </a>
      </div>
    </header>

    <main id="conteudo-principal">
      <slot />
    </main>

    <footer class="bg-slate-900 text-slate-400 py-10">
      <div class="max-w-6xl mx-auto px-4 flex flex-col md:flex-row justify-between items-center gap-4 text-sm">
        <p>© 2026 <span class="text-white font-semibold">Casa em Alta</span>. Todos os direitos reservados.</p>
        <div class="flex gap-6">
          <a href="/politica-de-privacidade" class="hover:text-white transition-colors">Política de Privacidade</a>
          <a href="/termos-de-uso" class="hover:text-white transition-colors">Termos de Uso</a>
        </div>
      </div>
    </footer>
  </body>
</html>
