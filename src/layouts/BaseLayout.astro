---
interface Props {
  title?: string;
  description?: string;
  image?: string;
  canonicalURL?: string;
  type?: 'website' | 'article';
  schema?: object;
}

const {
  title = 'UtilCasa - Reviews, Comparativos e Ofertas de Utilidades Domésticas',
  description = 'Encontre as melhores utilidades domésticas com reviews honestos, comparativos detalhados e as melhores ofertas do mercado.',
  image = '/images/og-default.png',
  type = 'website',
  schema,
} = Astro.props;

const canonicalURL = Astro.props.canonicalURL ?? new URL(Astro.url.pathname, Astro.site).href;
const imageURL = new URL(image, Astro.site).href;

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'UtilCasa',
  url: Astro.site?.href,
  description,
  potentialAction: {
    '@type': 'SearchAction',
    target: `${Astro.site}busca?q={search_term_string}`,
    'query-input': 'required name=search_term_string',
  },
};
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- SEO básico -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Open Graph -->
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={imageURL} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content="UtilCasa" />
    <meta property="og:locale" content="pt_BR" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageURL} />

    <!-- Fonte otimizada: preload + font-display swap -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap"
      rel="stylesheet"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
    </noscript>

    <!-- Schema Markup: WebSite (toda página) -->
    <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />

    <!-- Schema Markup: específico da página (ex: BlogPosting) -->
    {schema && <script type="application/ld+json" set:html={JSON.stringify(schema)} />}
  </head>
  <body class="bg-white font-sans text-slate-900 antialiased">
    <header class="sticky top-0 z-50 bg-white border-b border-slate-100 shadow-sm">
      <div class="max-w-6xl mx-auto px-4 h-16 flex items-center justify-between">
        <a href="/" class="flex items-center gap-2" aria-label="UtilCasa - Página inicial">
          <span class="text-2xl font-black text-orange-500">Util</span><span class="text-2xl font-black text-slate-800">Casa</span>
        </a>
        <nav aria-label="Menu principal" class="hidden md:flex items-center gap-8 text-sm font-medium text-slate-600">
          <a href="#posts" class="hover:text-orange-500 transition-colors">Melhores Posts</a>
          <a href="#sobre" class="hover:text-orange-500 transition-colors">Sobre</a>
          <a href="#contato" class="hover:text-orange-500 transition-colors">Contato</a>
        </nav>
        <a href="#posts" class="bg-orange-500 hover:bg-orange-600 text-white text-sm font-semibold px-4 py-2 rounded-full transition-colors">
          Ver Ofertas
        </a>
      </div>
    </header>

    <main id="conteudo-principal">
      <slot />
    </main>

    <footer class="bg-slate-900 text-slate-400 py-10">
      <div class="max-w-6xl mx-auto px-4 flex flex-col md:flex-row justify-between items-center gap-4 text-sm">
        <p>© 2025 <span class="text-white font-semibold">UtilCasa</span>. Todos os direitos reservados.</p>
        <p>Este site contém links de afiliados. Ao comprar, posso ganhar uma comissão sem custo extra para você.</p>
      </div>
    </footer>
  </body>
</html>
