  : isMultiprocessador ? '/images/multiprocessador/capa-multiprocessador.jpg'
  : isMaquinaGelo ? '/images/maquina-gelo/capa-maquina-gelo.jpg'
  : isChaleira ? '/images/chaleira/capa-chaleira.jpg'
  : isVaporizador ? '/images/vaporizador/capa-vaporizador.jpg'
  : isLavaLoucas ? '/images/lava-loucas/capa-lava-loucas.jpg'
  : isFornoEletrico ? '/images/forno-eletrico/capa-forno-eletrico.png'
  : isLavaSeca ? '/images/lava-seca/capa-lava-seca.jpg'
  : isComoEscolherLiquidificador ? '/images/liquidificador/capa-liquidificador.jpg'
  : isLiquidificadorVsProcessador ? '/images/liquidificador-vs-processador/capa-liquidificador-vs-processador.jpg'
  : isComoEscolherMicroondas ? '/images/microondas/capa-microondas.jpg'
  : undefined;
---

<BaseLayout
  title={`${post.titulo} - Casa em Alta`}
