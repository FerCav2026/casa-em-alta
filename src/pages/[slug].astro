    categoria: 'Comparativo',
    dataCriacao: '2026-06-18',
    dataModificacao: '2026-06-18',
  },
  'liquidificador-philips-walita-ri2110-review': {
    titulo: 'Philips Walita RI2110: Vale a Pena? Review Honesto',
    descricao: 'Testei o Philips Walita RI2110 por semanas e conto tudo: desempenho real, limpeza, ruído e para quem ele realmente vale a pena comprar.',
    categoria: 'Review',
