export function getStaticPaths() {
  return Object.keys({
    'melhores-aspiradores-po-2026': {},
    'airfryer-philips-vs-mondial': {},
    'organizadores-armario-barato': {},
    'robos-aspirador-custo-beneficio': {},
    'panela-pressao-eletrica-review': {},
    'itens-casa-30-reais-amazon': {},
    'como-escolher-frigideira': {},
    'purificador-agua-vale-pena': {},
    'kit-organizacao-cozinha': {},
    'melhor-multiprocessador-de-alimentos': {},
    'maquina-de-gelo-portatil': {},
    'chaleira-eletrica-com-controle-de-temperatura': {},
    'vaporizador-de-roupas-portatil': {},
    'forno-eletrico-portatil-vale-a-pena': {},
    'lava-loucas-midea-8-servicos-review': {},
    'lava-e-seca-ou-secadora-apartamento': {},
    'como-escolher-liquidificador': {},
    'liquidificador-vs-processador-de-alimentos': {},
    'como-escolher-microondas': {},
    'microondas-com-grill-vale-a-pena': {},
    'liquidificador-philips-walita-ri2110-review': {},
    'microondas-electrolux-mi41s-review': {},
    'como-escolher-airfryer': {},
    'melhores-liquidificadores-2026': {},
  }).map((slug) => ({ params: { slug } }));
}

const { slug } = Astro.params;
const post = posts[slug as string];
const postData = getPostBySlug(slug as string);

const blogPostingSchema = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: post.titulo,
  description: post.descricao,
  image: postData?.imagem ? new URL(postData.imagem, Astro.site).href : undefined,
  datePublished: post.dataCriacao + 'T00:00:00-03:00',
  dateModified: post.dataModificacao + 'T00:00:00-03:00',
  author: {
    '@type': 'Person',
    name: 'Claudia Castro',
    url: new URL('/sobre', Astro.site).href,
  },
  publisher: {
    '@type': 'Organization',
    name: 'Casa em Alta',
    url: Astro.site?.href,
  },
  url: new URL(`/${slug}`, Astro.site).href,
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': new URL(`/${slug}`, Astro.site).href,
  },
};

const isAspiradores = slug === 'melhores-aspiradores-po-2026';
const isAirfryer = slug === 'airfryer-philips-vs-mondial';
const isOrganizadores = slug === 'organizadores-armario-barato';
const isRobos = slug === 'robos-aspirador-custo-beneficio';
const isPanela = slug === 'panela-pressao-eletrica-review';
const isItens30 = slug === 'itens-casa-30-reais-amazon';
const isFrigideira = slug === 'como-escolher-frigideira';
const isPurificador = slug === 'purificador-agua-vale-pena';
const isKitCozinha = slug === 'kit-organizacao-cozinha';
const isMultiprocessador = slug === 'melhor-multiprocessador-de-alimentos';
const isMaquinaGelo = slug === 'maquina-de-gelo-portatil';
const isChaleira = slug === 'chaleira-eletrica-com-controle-de-temperatura';
const isVaporizador = slug === 'vaporizador-de-roupas-portatil';
const isLavaLoucas = slug === 'lava-loucas-midea-8-servicos-review';
const isFornoEletrico = slug === 'forno-eletrico-portatil-vale-a-pena';
const isLavaSeca = slug === 'lava-e-seca-ou-secadora-apartamento';
const isComoEscolherLiquidificador = slug === 'como-escolher-liquidificador';
const isLiquidificadorVsProcessador = slug === 'liquidificador-vs-processador-de-alimentos';
const isComoEscolherMicroondas = slug === 'como-escolher-microondas';
const isMicroondasGrill = slug === 'microondas-com-grill-vale-a-pena';
const isReviewRI2110 = slug === 'liquidificador-philips-walita-ri2110-review';
const isMI41SReview = slug === 'microondas-electrolux-mi41s-review';
const isComoEscolherAirfryer = slug === 'como-escolher-airfryer';
const isMelhoresLiquidificadores = slug === 'melhores-liquidificadores-2026';

const coverImage = isAspiradores ? '/images/aspiradores/capa-aspiradores.webp'
  : isAirfryer ? '/images/airfryer/capa-airfryer.webp'
  : isOrganizadores ? '/images/organizadores/capa-organizadores.webp'
  : isRobos ? '/images/robos/capa-robos.webp'
  : isPanela ? '/images/panela/capa-panela.webp'
  : isItens30 ? '/images/itens30/capa-itens30.webp'
  : isFrigideira ? '/images/frigideira/capa-frigideira.webp'
  : isPurificador ? '/images/purificador/capa-purificador.webp'
  : isKitCozinha ? '/images/kit-cozinha/capa-kit-cozinha.webp'
  : isMultiprocessador ? '/images/multiprocessador/capa-multiprocessador.webp'
  : isMaquinaGelo ? '/images/maquina-gelo/capa-maquina-gelo.webp'
  : isChaleira ? '/images/chaleira/capa-chaleira.webp'
  : isVaporizador ? '/images/vaporizador/capa-vaporizador.webp'
  : isLavaLoucas ? '/images/lava-loucas/capa-lava-loucas.webp'
  : isFornoEletrico ? '/images/forno-eletrico/capa-forno-eletrico.webp'
  : isLavaSeca ? '/images/lava-seca/capa-lava-seca.webp'
  : isComoEscolherLiquidificador ? '/images/liquidificador/capa-liquidificador.webp'
  : isLiquidificadorVsProcessador ? '/images/liquidificador-vs-processador/capa-liquidificador-vs-processador.webp'
  : isComoEscolherMicroondas ? '/images/microondas/capa-microondas.webp'
  : isMicroondasGrill ? '/images/microondas-grill/capa-microondas-grill.webp'
  : isReviewRI2110 ? '/images/liquidificador-ri2110/capa-ri2110.webp'
  : isMI41SReview ? '/images/microondas-mi41s/capa-mi41s.webp'
  : isComoEscolherAirfryer ? '/images/airfryer-guia/capa-como-escolher-airfryer.webp'
  : isMelhoresLiquidificadores ? '/images/melhores-liquidificadores/capa-melhores-liquidificadores.webp'
  : undefined;
---

<BaseLayout
  title={`${post.titulo} - Casa em Alta`}
  description={post.descricao}
  image={coverImage}
  type="article"
  schema={blogPostingSchema}
>
  <div class="max-w-4xl mx-auto px-4 py-12">
    <!-- Breadcrumb -->
    <nav class="flex items-center gap-2 text-sm text-slate-500 mb-8">
      <a href="/" class="hover:text-orange-500 transition-colors">Início</a>
      <span>/</span>
      {postData && (
        <>
          <a href={`/categorias/${postData.categoria}`} class="hover:text-orange-500 transition-colors">{postData.categoriaLabel}</a>
          <span>/</span>
        </>
      )}
      <span class="text-slate-800 font-medium truncate max-w-xs">{post.titulo}</span>
    </nav>

    <span class={`text-xs font-semibold px-2.5 py-1 rounded-full ${postData?.categoriaColor ?? 'bg-orange-100 text-orange-700'}`}>
      {postData?.categoriaLabel ?? post.categoria}
    </span>
    <h1 class="text-3xl md:text-4xl font-black text-slate-900 mt-2 mb-3">{post.titulo}</h1>
    <p class="text-slate-500 text-base mb-2">Por <strong class="text-slate-700">Claudia Castro</strong> &bull; Atualizado em {new Date(post.dataModificacao + 'T12:00:00').toLocaleDateString('pt-BR')}</p>
    <p class="text-slate-600 text-lg mb-10 leading-relaxed">{post.descricao}</p>

    {isAspiradores && (
      <div>

        <!-- Capa do artigo -->
        <div class="rounded-2xl overflow-hidden mb-8 shadow-md">
          <img
            src="/images/aspiradores/capa-aspiradores.webp"
            alt="Ranking dos 7 melhores aspiradores de pó de 2026: vertical, sem fio e robô"
            class="w-full h-auto object-cover"
            loading="eager"
          />
        </div>

        <!-- Introdução -->
        <div class="bg-orange-50 border border-orange-100 rounded-2xl p-6 mb-8">
          <p class="text-slate-700 leading-relaxed mb-3">
            Já usei vários modelos ao longo dos anos e posso dizer com certeza: a escolha certa do aspirador muda completamente a sua rotina. A dificuldade está em entender qual tipo serve melhor para o seu apartamento: vertical para limpeza rápida sem precisar guardar em lugar específico, sem fio para mais mobilidade entre os cômodos, ou robô para quem quer automatizar a limpeza do dia a dia e não perder tempo com isso.
          </p>
          <p class="text-slate-700 leading-relaxed">
            Nesta lista, reuni os 7 modelos mais vendidos e mais bem avaliados na Amazon Brasil em 2026, levando em conta potência, durabilidade, custo-benefício e facilidade de uso no dia a dia real.
          </p>
        </div>

        <!-- Curiosidade piso de madeira -->
        <div class="bg-blue-50 border border-blue-200 rounded-2xl p-6 mb-10">
          <p class="text-blue-800 font-bold text-base mb-2">Sabia disso? A curiosidade que pouca gente conhece antes de comprar</p>
          <p class="text-slate-700 leading-relaxed mb-3">
            Alguns modelos de robô aspirador especificam na embalagem a compatibilidade com dois tipos de piso de madeira: <strong>Madeira projetada</strong> (também chamada de laminado ou vinílico, um piso sintético com aparência de madeira) e <strong>Madeira de engenharia</strong> (assoalho com camadas reais de madeira, mais sensível à umidade).
          </p>
          <p class="text-slate-700 leading-relaxed">
            A diferença importa porque o módulo de passa-pano, quando muito úmido, pode danificar o piso de madeira de engenharia com o tempo. Se a sua casa tem esse tipo de piso, verifique se o modelo escolhido permite controlar o nível de umidade da mopa ou desativar o umedecimento.
          </p>
        </div>

        <!-- Produto 1 -->
        <div class="border border-slate-200 rounded-2xl overflow-hidden mb-8 shadow-sm">
          <div class="bg-orange-500 px-6 py-4">
            <p class="text-white font-black text-xl">1º lugar - Xiaomi Robot Vacuum S40 Pro</p>
            <p class="text-orange-100 text-sm mt-1">O mais vendido da Amazon em 2026: mapeamento preciso, passa pano e controle total pelo app</p>
          </div>
          <div class="p-6 flex flex-col md:flex-row gap-8">
            <div class="md:w-44 flex-shrink-0 flex items-center justify-center bg-white rounded-xl p-4 min-h-32">
              <img src="/images/aspiradores/xiaomi-s40-pro.webp" alt="Xiaomi Robot Vacuum S40 Pro" class="w-full h-auto object-contain rounded-lg" />
            </div>
            <div class="flex-1">
              <a href="https://amzn.to/42VCXwi" target="_blank" rel="nofollow noopener" class="block w-full bg-orange-500 hover:bg-orange-600 text-white text-center font-bold py-3 rounded-xl mb-3 transition-colors">
                Conferir preço na Amazon
              </a>
              <a href="https://meli.la/1JMBesX" target="_blank" rel="nofollow noopener" class="block w-full bg-orange-400 hover:bg-orange-500 text-white text-center font-bold py-3 rounded-xl mb-6 transition-colors">
                Conferir preço no Mercado Livre
              </a>
              <h3 class="font-bold text-slate-800 mb-3">Ficha Técnica</h3>
              <ul class="text-sm text-slate-600 space-y-1 mb-6">
                <li><strong>Potência de sucção:</strong> 6.500 Pa</li>
                <li><strong>Duração da bateria:</strong> até 180 minutos</li>
                <li><strong>Wi-Fi e app:</strong> Sim (Mi Home)</li>
                <li><strong>Passa pano:</strong> Sim, com controle de umidade</li>
                <li><strong>Navegação:</strong> Laser LDS com mapeamento em múltiplos andares</li>
                <li><strong>Compatibilidade de piso:</strong> Madeira projetada, madeira de engenharia, porcelanato, tapete</li>
              </ul>
              <div class="grid md:grid-cols-2 gap-4">
                <div>
                  <p class="text-green-600 font-bold text-sm mb-2">Pontos positivos</p>
                  <ul class="text-sm text-slate-600 space-y-1">
                    <li>Mapeamento por laser muito preciso</li>
                    <li>Controle de umidade da mopa pelo app</li>
                    <li>Funciona bem em tapetes e pisos mistos</li>
                    <li>Agendamento automático por cômodo</li>
                  </ul>
                </div>
                <div>
                  <p class="text-red-500 font-bold text-sm mb-2">Pontos negativos</p>
                  <ul class="text-sm text-slate-600 space-y-1">
                    <li>Preço mais elevado</li>
                    <li>Não esvazia a lixeira sozinho</li>
                  </ul>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Produto 2 -->
        <div class="border border-slate-200 rounded-2xl overflow-hidden mb-8 shadow-sm">
