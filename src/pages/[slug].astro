    'como-escolher-microondas': {},
  }).map((slug) => ({ params: { slug } }));
}

const { slug } = Astro.params;
const post = posts[slug as string];
const postData = getPostBySlug(slug as string);

const blogPostingSchema = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: post.titulo,
  description: post.descricao,
  image: postData?.imagem ? new URL(postData.imagem, Astro.site).href : undefined,
  datePublished: post.dataCriacao + 'T00:00:00-03:00',
  dateModified: post.dataModificacao + 'T00:00:00-03:00',
  author: {
    '@type': 'Person',
    name: 'Claudia Castro',
    url: new URL('/sobre', Astro.site).href,
  },
  publisher: {
    '@type': 'Organization',
    name: 'Casa em Alta',
    url: Astro.site?.href,
  },
  url: new URL(`/\${slug}`, Astro.site).href,
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': new URL(`/\${slug}`, Astro.site).href,
  },
};

const isAspiradores = slug === 'melhores-aspiradores-po-2026';
const isAirfryer = slug === 'airfryer-philips-vs-mondial';
const isOrganizadores = slug === 'organizadores-armario-barato';
const isRobos = slug === 'robos-aspirador-custo-beneficio';
const isPanela = slug === 'panela-pressao-eletrica-review';
const isItens30 = slug === 'itens-casa-30-reais-amazon';
const isFrigideira = slug === 'como-escolher-frigideira';
const isPurificador = slug === 'purificador-agua-vale-pena';
const isKitCozinha = slug === 'kit-organizacao-cozinha';
const isMultiprocessador = slug === 'melhor-multiprocessador-de-alimentos';
const isMaquinaGelo = slug === 'maquina-de-gelo-portatil';
const isChaleira = slug === 'chaleira-eletrica-com-controle-de-temperatura';
const isVaporizador = slug === 'vaporizador-de-roupas-portatil';
const isLavaLoucas = slug === 'lava-loucas-midea-8-servicos-review';
const isFornoEletrico = slug === 'forno-eletrico-portatil-vale-a-pena';
const isLavaSeca = slug === 'lava-e-seca-ou-secadora-apartamento';
const isComoEscolherLiquidificador = slug === 'como-escolher-liquidificador';
const isLiquidificadorVsProcessador = slug === 'liquidificador-vs-processador-de-alimentos';
const isComoEscolherMicroondas = slug === 'como-escolher-microondas';

const coverImage = isAspiradores ? '/images/aspiradores/capa-aspiradores.png'
  : isAirfryer ? '/images/airfryer/capa-airfryer.png'
  : isOrganizadores ? '/images/organizadores/capa-organizadores.png'
  : isRobos ? '/images/robos/capa-robos.png'
  : isPanela ? '/images/panela/capa-panela.png'
  : isItens30 ? '/images/itens30/capa-itens30.png'
  : isFrigideira ? '/images/frigideira/capa-frigideira.png'
