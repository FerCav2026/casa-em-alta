                    <li>Não esvazia a lixeira sozinho</li>
                  </ul>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Produto 2 -->
        <div class="border border-slate-200 rounded-2xl overflow-hidden mb-8 shadow-sm">
          <div class="bg-slate-800 px-6 py-4">
            <p class="text-white font-black text-xl">2º lugar - Dreame D10 Plus Gen 2</p>
            <p class="text-slate-300 text-sm mt-1">Esvaziamento automático por até 90 dias e sucção de 6.000 Pa</p>
          </div>
          <div class="p-6 flex flex-col md:flex-row gap-8">
            <div class="md:w-44 flex-shrink-0 flex items-center justify-center bg-white rounded-xl p-4 min-h-32">
              <img src="/images/aspiradores/dreame-d10-plus.jpg" alt="Dreame D10 Plus Gen 2" class="w-full h-auto object-contain rounded-lg" />
            </div>
            <div class="flex-1">
