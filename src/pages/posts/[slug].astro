    categoria: 'Guia',
    dataCriacao: '2026-05-01',
    dataModificacao: '2026-05-22',
  },
};

export function getStaticPaths() {
  return Object.keys({
    'melhores-aspiradores-po-2026': {},
    'airfryer-philips-vs-mondial': {},
    'organizadores-armario-barato': {},
    'robos-aspirador-custo-beneficio': {},
    'panela-pressao-eletrica-review': {},
    'itens-casa-30-reais-amazon': {},
    'como-escolher-frigideira': {},
    'purificador-agua-vale-pena': {},
    'kit-organizacao-cozinha': {},
  }).map((slug) => ({ params: { slug } }));
}

const { slug } = Astro.params;
const post = posts[slug as string];

const blogPostingSchema = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: post.titulo,
  description: post.descricao,
  datePublished: post.dataCriacao,
  dateModified: post.dataModificacao,
  author: {
    '@type': 'Person',
    name: 'Casa em Alta',
    url: Astro.site?.href,
  },
  publisher: {
    '@type': 'Organization',
    name: 'Casa em Alta',
    url: Astro.site?.href,
  },
  url: new URL(`/posts/${slug}`, Astro.site).href,
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': new URL(`/posts/${slug}`, Astro.site).href,
  },
};

const isAspiradores = slug === 'melhores-aspiradores-po-2026';
const isAirfryer = slug === 'airfryer-philips-vs-mondial';
const isOrganizadores = slug === 'organizadores-armario-barato';
const isRobos = slug === 'robos-aspirador-custo-beneficio';
const isPanela = slug === 'panela-pressao-eletrica-review';
const isItens30 = slug === 'itens-casa-30-reais-amazon';
const isFrigideira = slug === 'como-escolher-frigideira';
const isPurificador = slug === 'purificador-agua-vale-pena';
const isKitCozinha = slug === 'kit-organizacao-cozinha';
---

<BaseLayout
  title={`${post.titulo} - Casa em Alta`}
