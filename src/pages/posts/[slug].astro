---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getPostBySlug } from '../../data/posts';

const posts: Record<string, { titulo: string; descricao: string; categoria: string; dataCriacao: string; dataModificacao: string }> = {
  'melhores-aspiradores-po-2026': {
    titulo: 'Os 7 Melhores Aspiradores de Pó de 2026',
    descricao: 'Testamos os modelos mais vendidos da Amazon para descobrir qual realmente vale o preço. Confira nosso ranking com robôs, verticais e tradicionais.',
    categoria: 'Review',
    dataCriacao: '2026-01-10',
    dataModificacao: '2026-05-26',
  },
  'airfryer-philips-vs-mondial': {
    titulo: 'Airfryer Philips vs Mondial: Qual Comprar em 2026?',
    descricao: 'Comparamos consumo de energia, capacidade, facilidade de limpeza e resultado final. A resposta vai te surpreender.',
    categoria: 'Comparativo',
    dataCriacao: '2026-02-05',
    dataModificacao: '2026-05-15',
  },
  'organizadores-armario-barato': {
    titulo: '10 Organizadores de Armário Baratos que Valem Cada Centavo',
    descricao: 'Encontramos os melhores organizadores por menos de R$ 50 que transformam qualquer armário bagunçado.',
    categoria: 'Oferta',
    dataCriacao: '2026-02-20',
    dataModificacao: '2026-05-10',
  },
  'robos-aspirador-custo-beneficio': {
    titulo: 'Robôs Aspiradores: Os 5 Melhores Custo-Benefício',
    descricao: 'Você realmente precisa gastar mais de R$ 1.000? Testamos opções de R$ 300 a R$ 2.000.',
    categoria: 'Comparativo',
    dataCriacao: '2026-03-01',
    dataModificacao: '2026-05-18',
  },
  'panela-pressao-eletrica-review': {
    titulo: 'Panela de Pressão Elétrica: Review Completo após 6 Meses de Uso',
    descricao: 'Usamos por 6 meses e contamos tudo: pontos fortes, limitações e se realmente economiza tempo na cozinha.',
    categoria: 'Review',
    dataCriacao: '2026-03-15',
    dataModificacao: '2026-05-12',
  },
  'itens-casa-30-reais-amazon': {
    titulo: '15 Itens Incríveis para Casa por até R$ 30 na Amazon',
    descricao: 'Garimpos que valem muito mais do que custam. Atualizamos essa lista toda semana com os melhores achados.',
    categoria: 'Oferta',
    dataCriacao: '2026-04-01',
    dataModificacao: '2026-05-25',
  },
  'como-escolher-frigideira': {
    titulo: 'Como Escolher a Frigideira Certa para Cada Tipo de Fogão',
    descricao: 'Indução, gás ou elétrico? Antiaderente ou inox? Este guia resolve de uma vez por todas essa dúvida.',
    categoria: 'Guia',
    dataCriacao: '2026-04-10',
    dataModificacao: '2026-05-10',
  },
  'purificador-agua-vale-pena': {
    titulo: 'Purificador de Água Realmente Vale a Pena? Testamos 4 Modelos',
    descricao: 'Fizemos testes de qualidade da água e calculamos o custo por litro de cada modelo. Os resultados são reveladores.',
    categoria: 'Review',
    dataCriacao: '2026-04-20',
    dataModificacao: '2026-05-20',
  },
  'kit-organizacao-cozinha': {
    titulo: 'Kit Organização de Cozinha: Monte o seu por R$ 150',
    descricao: 'Selecionamos os melhores produtos para organizar sua cozinha do zero sem gastar muito.',
    categoria: 'Guia',
    dataCriacao: '2026-05-01',
    dataModificacao: '2026-05-22',
  },
};

export function getStaticPaths() {
  return Object.keys({
    'melhores-aspiradores-po-2026': {},
    'airfryer-philips-vs-mondial': {},
    'organizadores-armario-barato': {},
    'robos-aspirador-custo-beneficio': {},
    'panela-pressao-eletrica-review': {},
    'itens-casa-30-reais-amazon': {},
    'como-escolher-frigideira': {},
    'purificador-agua-vale-pena': {},
    'kit-organizacao-cozinha': {},
  }).map((slug) => ({ params: { slug } }));
}

const { slug } = Astro.params;
const post = posts[slug as string];
const postData = getPostBySlug(slug as string);

const blogPostingSchema = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: post.titulo,
  description: post.descricao,
  datePublished: post.dataCriacao,
  dateModified: post.dataModificacao,
  author: {
    '@type': 'Person',
    name: 'Casa em Alta',
    url: Astro.site?.href,
  },
  publisher: {
    '@type': 'Organization',
    name: 'Casa em Alta',
    url: Astro.site?.href,
  },
  url: new URL(`/posts/${slug}`, Astro.site).href,
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': new URL(`/posts/${slug}`, Astro.site).href,
  },
};

const isAspiradores = slug === 'melhores-aspiradores-po-2026';
const isAirfryer = slug === 'airfryer-philips-vs-mondial';
const isOrganizadores = slug === 'organizadores-armario-barato';
const isRobos = slug === 'robos-aspirador-custo-beneficio';
const isPanela = slug === 'panela-pressao-eletrica-review';
const isItens30 = slug === 'itens-casa-30-reais-amazon';
const isFrigideira = slug === 'como-escolher-frigideira';
const isPurificador = slug === 'purificador-agua-vale-pena';
const isKitCozinha = slug === 'kit-organizacao-cozinha';

const coverImage = isAspiradores ? '/images/aspiradores/capa-aspiradores.png'
  : isAirfryer ? '/images/airfryer/capa-airfryer.png'
  : isOrganizadores ? '/images/organizadores/capa-organizadores.png'
  : isRobos ? '/images/robos/capa-robos.png'
  : isPanela ? '/images/panela/capa-panela.png'
  : isItens30 ? '/images/itens30/capa-itens30.png'
  : undefined;
---

<BaseLayout
  title={`${post.titulo} - Casa em Alta`}
  description={post.descricao}
  image={coverImage}
  type="article"
  schema={blogPostingSchema}
>
  <div class="max-w-4xl mx-auto px-4 py-12">
    <!-- Breadcrumb -->
    <nav class="flex items-center gap-2 text-sm text-slate-500 mb-8">
      <a href="/" class="hover:text-orange-500 transition-colors">Início</a>
      <span>/</span>
      {postData && (
        <>
          <a href={`/categorias/${postData.categoria}`} class="hover:text-orange-500 transition-colors">{postData.categoriaLabel}</a>
          <span>/</span>
        </>
      )}
      <span class="text-slate-800 font-medium truncate max-w-xs">{post.titulo}</span>
    </nav>

    <span class={`text-xs font-semibold px-2.5 py-1 rounded-full ${postData?.categoriaColor ?? 'bg-orange-100 text-orange-700'}`}>
      {postData?.categoriaLabel ?? post.categoria}
    </span>
    <h1 class="text-3xl md:text-4xl font-black text-slate-900 mt-2 mb-3">{post.titulo}</h1>
    <p class="text-slate-500 text-base mb-2">Por <strong class="text-slate-700">Casa em Alta</strong> &bull; Atualizado em 26/05/2026</p>
    <p class="text-slate-600 text-lg mb-10 leading-relaxed">{post.descricao}</p>

    {isAspiradores && (
      <div>

        <!-- Capa do artigo -->
        <div class="rounded-2xl overflow-hidden mb-8 shadow-md">
          <img
            src="/images/aspiradores/capa-aspiradores.png"
            alt="Os melhores aspiradores de pó de 2026: robôs, verticais e portáteis"
            class="w-full h-auto object-cover"
            loading="eager"
          />
        </div>

        <!-- Introdução -->
        <div class="bg-orange-50 border border-orange-100 rounded-2xl p-6 mb-8">
          <p class="text-slate-700 leading-relaxed mb-3">
            Já usei vários modelos ao longo dos anos e posso dizer com certeza: a escolha certa do aspirador muda completamente a sua rotina. Tenho um aspirador vertical que uso para limpezas rápidas, mas foi o robô aspirador que realmente transformou o meu dia a dia. Enquanto cuido da louça ou faço outra tarefa, ele vai pelo chão aspirando e ainda passa pano. Uma liberdade que não tem preço.
          </p>
          <p class="text-slate-700 leading-relaxed">
            Nesta lista, reuni os 7 modelos mais vendidos e mais bem avaliados na Amazon Brasil em 2026, levando em conta potência, durabilidade, custo-benefício e facilidade de uso no dia a dia real.
          </p>
        </div>

        <!-- Curiosidade piso de madeira -->
        <div class="bg-blue-50 border border-blue-200 rounded-2xl p-6 mb-10">
