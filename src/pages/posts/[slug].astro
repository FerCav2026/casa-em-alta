        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
      </svg>
      Voltar para o início
    </a>

    <span class="text-xs font-semibold text-orange-500 uppercase tracking-widest">{post.categoria}</span>
