---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { posts } from '../../data/posts';
---

<BaseLayout
  title="Todos os Artigos — Casa em Alta"
  description="Reviews, comparativos e guias de compra para você tomar a melhor decisão na hora de equipar e organizar sua casa."
>
  <div class="max-w-6xl mx-auto px-4 py-16">

    <!-- Cabeçalho -->
    <div class="mb-12">
      <a href="/" class="text-sm text-slate-500 hover:text-orange-500 transition-colors">← Início</a>
      <h1 class="text-3xl md:text-4xl font-black text-slate-900 mt-4">Todos os Artigos</h1>
      <p class="text-slate-500 mt-2 text-lg">Reviews, comparativos e guias de compra para você escolher melhor.</p>
    </div>

    <!-- Grid de artigos -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {posts.map((post) => (
        <article class="group bg-white rounded-2xl border border-slate-100 shadow-sm hover:shadow-md transition-all hover:-translate-y-1 overflow-hidden flex flex-col">
          <div class="w-full h-48 overflow-hidden bg-gradient-to-br from-slate-100 to-slate-200 flex items-center justify-center">
            {post.imagem ? (
              <img
                src={post.imagem}
                alt={`Capa: ${post.titulo}`}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                loading="lazy"
              />
            ) : (
              <div class="w-12 h-12 rounded-xl bg-orange-100 flex items-center justify-center">
                <svg class="w-6 h-6 text-orange-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                </svg>
              </div>
            )}
          </div>

          <div class="p-5 flex flex-col flex-1 gap-3">
            <div class="flex items-center justify-between">
              <span class={`text-xs font-semibold px-2.5 py-1 rounded-full ${post.categoriaColor}`}>
                {post.categoriaLabel}
              </span>
              <span class="text-xs text-slate-400">{post.tempo}</span>
            </div>

            <h2 class="font-bold text-slate-900 text-base leading-snug group-hover:text-orange-500 transition-colors">
              <a href={`/posts/${post.slug}`}>{post.titulo}</a>
            </h2>

            <p class="text-sm text-slate-500 leading-relaxed flex-1">{post.resumo}</p>

            <a
              href={`/posts/${post.slug}`}
              class="text-sm font-semibold text-orange-500 hover:text-orange-600 flex items-center gap-1 mt-auto transition-colors"
            >
              Ler artigo completo
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </a>
          </div>
        </article>
      ))}
    </div>

  </div>
</BaseLayout>
